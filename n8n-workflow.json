{
  "name": "NIN Verification Workflow",
  "nodes": [
    {
      "parameters": {
        "path": "verify-nin",
        "responseMode": "lastNode",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
