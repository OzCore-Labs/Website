        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "nin",
              "value": "={{$json.body.nin}}"
            }
          ]
        },
        "options": {}
      },
      "name": "Placeholder API Call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.verified}}",
              "value2": true
            }
          ]
        }
      },
      "name": "Check Verification",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        650,
        300
      ]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Placeholder API Call",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Placeholder API Call": {
      "main": [
        [
          {
            "node": "Check Verification",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {}
